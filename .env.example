# ── OpenRouter (бесплатно без карты, Llama 3.3 70B) ───────────────────────────
# Регистрация: openrouter.ai → Sign in with Google → Keys → Create key
# Карта не нужна. Бесплатная модель: meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# ── HH.ru OAuth (для поиска вакансий на HH.ru) ─────────────────────────────────
# Зарегистрировать приложение: dev.hh.ru/admin → Создать приложение
# Тип: Настольное приложение, название: JobHunterBot
HH_CLIENT_ID=your_client_id
HH_CLIENT_SECRET=your_client_secret

# ── Telegram Bot (отправка уведомлений) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAH... # @BotFather
TELEGRAM_CHAT_ID=123456789           # узнать у @userinfobot

# ── Telegram Account (чтение каналов через Pyrogram) ───────────────────────────
TELEGRAM_API_ID=12345678             # my.telegram.org → App configuration
TELEGRAM_API_HASH=abcdef1234...      # my.telegram.org → App configuration
